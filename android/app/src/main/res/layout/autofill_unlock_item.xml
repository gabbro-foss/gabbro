<?xml version="1.0" encoding="utf-8"?>
<!--
    Autofill dropdown chip shown when the vault is locked.
    RemoteViews is rendered by the Android system UI (not by Gabbro),
    so only a small subset of views and attributes are supported.
    TextView is always safe; ConstraintLayout and most custom views are not.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_lock"
        android:contentDescription="@null" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="@string/autofill_unlock_label"
        android:textSize="14sp" />

</LinearLayout>