// Gabbro crypto stack — source of truth for gabbro_crypto_stack_flow.svg
// Render:  dot -Tsvg gabbro_crypto_stack_flow.dot -o gabbro_crypto_stack_flow.svg
//
// Reflects the implementation as of file-format VERSION 11 (ADR-018):
//   passphrase -> Argon2id -> HKDF-SHA256 -> AES-256-GCM
//   The vault key is derived straight from the Argon2id output; the X25519 +
//   ML-KEM-1024 hybrid key-exchange layer was removed as non-load-bearing.
//   The plaintext header is bound as AES-GCM AAD (v7+); the YubiKey multi-key
//   keyslot layer is unchanged (wrapping_key / vault_key_master / passphrase_blob
//   / per-key key_blob). v2-v10 vaults keep the legacy hybrid derivation, read-only,
//   to open and migrate them (dropped entirely at RT-3).
//   Arrows read top-down as the UNLOCK / key-derivation path; sealing is the
//   inverse (see notes).

digraph gabbro_crypto_stack {
  rankdir=TB;
  bgcolor="white";
  labelloc="t";
  label=<<b>Gabbro crypto stack &#183; file-format VERSION 11</b><br/><font point-size="10">passphrase &#8594; Argon2id &#8594; HKDF-SHA256 &#8594; AES-256-GCM (header bound as AAD)</font>>;
  fontname="Helvetica"; fontsize=14;
  node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", color="#444444", penwidth=1.1];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  // ───────── Key derivation from the passphrase ─────────
  subgraph cluster_kdf {
    label="Key derivation (from passphrase)"; fontsize=11; style="rounded,dashed"; color="#B08900";
    pass   [label="passphrase", fillcolor="#FDE9C8"];
    argon  [label="Argon2id KDF\nRFC 9106 · m=64 MiB, t=25, p=4\nsalt + params from header → 96 bytes", fillcolor="#F6C667"];
  }
  pass -> argon;

  // ───────── Vault-key derivation (HKDF straight from Argon2id) ─────────
  subgraph cluster_hkdf {
    label="Vault-key derivation (ADR-018)"; fontsize=11; style="rounded,dashed"; color="#3C8C3C";
    hkdf   [label="HKDF-SHA256 (RFC 5869)\nsalt = hkdf_salt (32B, header)\nikm = Argon2id output (96B)\ninfo = \"gabbro-vault-key-from-argon2id-v1\"", fillcolor="#8FD18F"];
    ik     [label="intermediate key (32B)", fillcolor="#8FD18F"];
  }
  argon -> hkdf;
  hkdf -> ik;

  // ───────── Vault type A: passphrase only ─────────
  subgraph cluster_pp {
    label="Vault type A — passphrase only"; fontsize=11; style="rounded,dashed"; color="#3F72B0";
    vk_pp  [label="vault key = intermediate key", fillcolor="#CFE0F5"];
    aes_pp [label="AES-256-GCM\nencrypt / decrypt vault body\nAAD = plaintext header", fillcolor="#9CC2EE"];
  }
  ik -> vk_pp [label=" no YubiKey"];
  vk_pp -> aes_pp;

  // ───────── Vault type B: passphrase + 2–4 YubiKeys ─────────
  subgraph cluster_yk {
    label="Vault type B — passphrase + 2–4 YubiKeys (multi-key)"; fontsize=11; style="rounded,dashed"; color="#9B59B6";
    pblob   [label="passphrase_blob\n= AES-GCM(intermediate key, wrapping_key)", fillcolor="#EBD2F0"];
    wrap    [label="wrapping_key (random, stable)", fillcolor="#E0BEE8"];
    yk_hw   [label="YubiKey FIDO2\nhmac-secret (per registered key)", style="rounded,filled,bold", fillcolor="#F5B7B1"];
    combine [label="combine_yubikey(\nwrapping_key, hmac_secret_i, salt_i)\ninfo = \"gabbro-yubikey-v1\"", fillcolor="#E0BEE8"];
    kblob   [label="key_blob_i\n= AES-GCM(combined_i, vault_key_master)\none per registered key (2–4)", fillcolor="#EBD2F0"];
    vkm     [label="vault_key_master (random)", fillcolor="#D9A7E3"];
    aes_yk  [label="AES-256-GCM\nencrypt / decrypt vault body\nAAD = plaintext header", fillcolor="#9CC2EE"];
  }
  ik -> pblob [label=" unlock: decrypt"];
  pblob -> wrap;
  wrap -> combine;
  yk_hw -> combine [label=" hmac_secret_i"];
  combine -> kblob;
  kblob -> vkm [label=" unlock: decrypt"];
  vkm -> aes_yk;

  // ───────── Output ─────────
  body [label="sealed .gabbro file\nplaintext header + body (ciphertext + GCM tag)\n0600, atomic temp+rename, symlink-rejected", shape=note, fillcolor="#ECECEC"];
  aes_pp -> body;
  aes_yk -> body;

  // ───────── Notes ─────────
  note_aad [shape=note, fillcolor="#FFF7D6", color="#B08900",
    label="VERSION 7+ header integrity: the entire plaintext header\n— Argon2 params, salts, YubiKey records, alias, passphrase_blob —\nis the AES-GCM AAD. (Vaults ≤ v10 also bind the ML-KEM\nciphertext + X25519 pubkey they carry.) Any header tamper\nmakes body decryption fail."];
  note_v11 [shape=note, fillcolor="#FFF7D6", color="#B08900",
    label="VERSION 11 (ADR-018): the vault key is derived straight from\nthe Argon2id output via HKDF, removing the X25519 + ML-KEM-1024\nhybrid key exchange (it was non-load-bearing — both keypairs\nderived from the passphrase). v2–v10 keep the legacy hybrid\nderivation, read-only, to open and migrate them; derivation is\nversion-dispatched on the parsed file version. Dropped at RT-3."];
  note_pp [shape=note, fillcolor="#FFF7D6", color="#B08900",
    label="Passphrase change re-runs Argon2id + HKDF and re-wraps\nwrapping_key into a new passphrase_blob; key_blobs and\nthe vault body are unchanged (any one key still opens).\nYubiKey slots keep the \"…-v1\" combiner at every version."];
  body -> note_aad  [style=invis];
  body -> note_v11  [style=invis];
  body -> note_pp   [style=invis];
}
